{
  "name": "threshold",
  "private": true,
  "version": "3.5.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:grok": "vite --mode grok",
    "build": "vite build --mode pages",
    "build:grok": "vite build --mode grok",
    "preview": "vite preview --outDir dist-pages",
    "electron:dev": "npm run build && electron .",
    "init:native": "node scripts/init-native.cjs",
    "cap:sync": "npx cap sync",
    "cap:open": "npx cap open android",
    "package:android": "node scripts/package-android.cjs",
    "package:win": "node scripts/package-win.cjs",
    "build:icons": "node scripts/build-icons.cjs",
    "gimp:install": "node scripts/install-gimp-plugin.cjs",
    "blender:install": "node scripts/install-blender-addon.cjs",
    "cap:assets": "npx capacitor-assets generate --assetPath icons --iconBackgroundColor \"#000000\" --iconBackgroundColorDark \"#000000\" --splashBackgroundColor \"#000000\" --splashBackgroundColorDark \"#000000\""
  },
  "devDependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.2.0",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^2.1.8",
    "vite": "^6.2.0"
  },
  "dependencies": {
    "@capacitor/core": "^7.2.0",
    "cannon-es": "^0.20.0",
    "peerjs": "^1.5.4",
    "three": "^0.182.0"
  }
}
