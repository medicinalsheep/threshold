{
  "format": "threshold-bootcamp",
  "version": 6,
  "root": "./training/bootcamp",
  "note": "Portable path in repo. Override with config/bootcamp.local.json or BOOTCAMP_ROOT env (gitignored). Wave5 = 10.13 product power pack.",
  "ollamaHost": "http://127.0.0.1:11434",
  "models": {
    "small": {
      "name": "threshold-mini-npc",
      "base": "llama3.2:3b",
      "datasets": [
        "datasets/small/critical.jsonl",
        "datasets/small/wave5_product.jsonl",
        "datasets/small/safety_npc.jsonl",
        "datasets/small/classify.jsonl",
        "datasets/small/npc.jsonl",
        "datasets/small/guide.jsonl"
      ],
      "modelfile": "modelfiles/threshold-mini-npc.Modelfile",
      "maxExamples": 112
    },
    "medium": {
      "name": "threshold-mini-dev",
      "base": "qwen2.5-coder:1.5b",
      "datasets": [
        "datasets/medium/critical.jsonl",
        "datasets/medium/wave5_product.jsonl",
        "datasets/medium/safety.jsonl",
        "datasets/medium/plan_code.jsonl",
        "datasets/medium/planning.jsonl",
        "datasets/medium/performance.jsonl",
        "datasets/medium/compiler.jsonl"
      ],
      "modelfile": "modelfiles/threshold-mini-dev.Modelfile",
      "maxExamples": 96,
      "note": "wave5 product + safety + plan/code + planning + performance + compiler"
    },
    "large_dev": {
      "name": "threshold-dev",
      "base": "qwen2.5-coder:7b",
      "datasets": ["datasets/large/scenes.jsonl"],
      "modelfile": "modelfiles/threshold-dev.Modelfile",
      "downloadRequired": true,
      "sizeGb": 4.7
    },
    "large_scenes": {
      "name": "threshold-large-scenes",
      "base": "llama3.1:8b",
      "datasets": ["datasets/large/scenes.jsonl"],
      "modelfile": "modelfiles/threshold-large.Modelfile",
      "downloadRequired": true,
      "sizeGb": 4.9
    }
  }
}
