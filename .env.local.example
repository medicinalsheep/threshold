# Copy to .env.local (gitignored) — tune for your PC.
# Ollama runs locally; Threshold repo may be on a network drive (slow builds, fast API).

VITE_OLLAMA_URL=http://127.0.0.1:11434
VITE_OLLAMA_MODEL=llama3.2:3b
# Mini models (GitHub Modelfile + local ollama pull):
VITE_OLLAMA_TIER_SMALL=threshold-mini-npc
VITE_OLLAMA_TIER_MEDIUM=threshold-mini-dev
VITE_OLLAMA_TIER_LARGE=threshold-dev

# Optional ramdisk bootcamp (gitignored bootcamp.local.json instead):
# BOOTCAMP_ROOT=Z:/Threshold training bootcamp