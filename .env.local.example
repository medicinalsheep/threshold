# Copy to .env.local (gitignored) — tune for your PC.
# Ollama runs locally; Threshold repo may be on a network drive (slow builds, fast API).

VITE_OLLAMA_URL=http://127.0.0.1:11434
VITE_OLLAMA_MODEL=llama3.2:3b
# After bootcamp:create use threshold-* or stock models:
VITE_OLLAMA_TIER_SMALL=threshold-small
VITE_OLLAMA_TIER_MEDIUM=threshold-medium
VITE_OLLAMA_TIER_LARGE=threshold-large

# CLI benchmarks (PowerShell):
# $env:OLLAMA_HOST="http://127.0.0.1:11434"