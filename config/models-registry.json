{
  "format": "threshold-models-registry",
  "version": 1,
  "policy": {
    "onGitHub": "JSONL datasets, Modelfiles, registry metadata — no GGUF weights, no API keys, no local paths",
    "localOnly": "Ollama weights in ~/.ollama/models, .env.local, bootcamp.local.json, dist-store benchmarks",
    "largeModels": "User runs ollama pull for base weights; npm run models:mini creates thin custom layers"
  },
  "roadmap": {
    "vision": "On-device mini agents now; large scene/video models later (Trellis-class 3D + Veo-class video) with tiered download",
    "crossDevice": "Mini models on phone/desktop via Ollama; cloud optional for large only"
  },
  "localRecommended": {
    "deviceClass": "RTX 2060 6GB laptop (reference bench 2026-07-10)",
    "numCtx": 4096,
    "command": "npm run ollama:benchmark -- --all",
    "tiers": {
      "small": { "model": "llama3.2:3B", "why": "~70 tok/s, 100% workflow probes, best interactive NPC/intent" },
      "medium": { "model": "llama3.2:3B", "alt": "qwen2.5:latest", "why": "3B fast patches; qwen2.5 stronger JS when latency OK" },
      "large": { "model": "qwen2.5:latest", "alt": "gemma4:latest", "why": "qwen2.5 ~15 tok/s full scenes; gemma4 quality OK but 9.6GB + slow cold load" }
    },
    "avoid": {
      "qwen3:4b": "Thinking model — burns num_predict on CoT; empty code after strip unless think:false + more tokens; still rambling for JS",
      "gemma4:latest": "Interactive sessions — cold load 60–85s class; OK for offline batch large only"
    }
  },
  "mini": [
    {
      "id": "threshold-mini-npc",
      "tier": "small",
      "label": "NPC chat + intent",
      "basePull": "llama3.2:3b",
      "baseSizeGb": 2.0,
      "modelfile": "training/bootcamp/modelfiles/threshold-mini-npc.Modelfile",
      "datasets": ["training/bootcamp/datasets/small/npc.jsonl", "training/bootcamp/datasets/small/classify.jsonl"],
      "onGitHub": true
    },
    {
      "id": "threshold-mini-dev",
      "tier": "medium",
      "label": "Compiler patches (mini)",
      "basePull": "qwen2.5-coder:1.5b-base",
      "baseSizeGb": 0.99,
      "modelfile": "training/bootcamp/modelfiles/threshold-mini-dev.Modelfile",
      "datasets": ["training/bootcamp/datasets/medium/compiler.jsonl"],
      "onGitHub": true
    }
  ],
  "community": [
    {
      "id": "llama3.2:3B",
      "tier": "small",
      "label": "General 3B (2060 sweet spot)",
      "basePull": "llama3.2:3b",
      "baseSizeGb": 2.0,
      "onGitHub": false,
      "workflowFit": "excellent"
    },
    {
      "id": "qwen2.5:latest",
      "tier": "large",
      "label": "Qwen2.5 7B general",
      "basePull": "qwen2.5:latest",
      "baseSizeGb": 4.7,
      "onGitHub": false,
      "workflowFit": "excellent-slow"
    },
    {
      "id": "qwen3:4b",
      "tier": "small",
      "label": "Qwen3 4B (thinking)",
      "basePull": "qwen3:4b",
      "baseSizeGb": 2.5,
      "onGitHub": false,
      "workflowFit": "poor-for-code-without-finetune"
    },
    {
      "id": "gemma4:latest",
      "tier": "large",
      "label": "Gemma4 8B multimodal",
      "basePull": "gemma4:latest",
      "baseSizeGb": 9.6,
      "onGitHub": false,
      "workflowFit": "good-heavy"
    }
  ],
  "large": [
    {
      "id": "threshold-dev",
      "tier": "large",
      "label": "Full scene scripts",
      "basePull": "qwen2.5-coder:7b",
      "baseSizeGb": 4.7,
      "modelfile": "training/bootcamp/modelfiles/threshold-dev.Modelfile",
      "downloadRequired": true,
      "onGitHub": "modelfile-only"
    },
    {
      "id": "threshold-large-scenes",
      "tier": "large",
      "label": "Scene architect (8B)",
      "basePull": "llama3.1:8b",
      "baseSizeGb": 4.9,
      "modelfile": "training/bootcamp/modelfiles/threshold-large.Modelfile",
      "downloadRequired": true,
      "onGitHub": "modelfile-only"
    }
  ]
}