{
  "format": "threshold-avatar-manifest",
  "version": 3,
  "defaultHeightM": 1.75,
  "preferredRoot": "StarterAvatar",
  "animationClips": ["walk", "Walk", "locomotion", "idle", "Idle"],
  "namedParts": ["legL", "legR", "armL", "armR", "torso", "head", "hips", "neck", "hair_anchor"],
  "fpsHideParts": ["head", "hairCap", "neck"],
  "attachPoints": {
    "hair": ["hair_anchor", "head"],
    "torso_prop": ["torso", "prop_torso", "shoulders"],
    "head_prop": ["head", "prop_head", "hair_anchor"],
    "neck": ["neck", "collar", "head"],
    "hips": ["hips", "torso"],
    "hand_r": ["hand_R", "hand_r", "armR"],
    "hand_l": ["hand_L", "hand_l", "armL"]
  },
  "modsCatalog": "config/avatar-mods.json",
  "modsNote": "Full MOD pack lives in avatar-mods.json (slots, presets, 50+ pieces). Legacy inline mods below kept as stubs.",
  "lodDefaults": {
    "distances": [0, 10, 22],
    "note": "Avatar mesh LOD (m) — closer than world MeshLod defaults for faces"
  },
  "bodies": {
    "male_default": {
      "glb": "starter_avatar.glb",
      "heightM": 1.75,
      "label": "Male formed",
      "form": "male",
      "fallback": { "torsoScale": [1.06, 1.02, 0.98], "hipScale": [1, 1, 1] },
      "lods": [
        { "level": 0, "file": "starter_avatar.glb", "distance": 0 },
        { "level": 1, "file": "starter_avatar_lod1.glb", "distance": 10 },
        { "level": 2, "file": "starter_avatar_lod2.glb", "distance": 22 }
      ]
    },
    "female_default": {
      "glb": "starter_avatar_female.glb",
      "heightM": 1.65,
      "label": "Female formed",
      "form": "female",
      "fallback": { "torsoScale": [0.9, 0.98, 0.88], "hipScale": [1.1, 1, 1.06] },
      "lods": [
        { "level": 0, "file": "starter_avatar_female.glb", "distance": 0 },
        { "level": 1, "file": "starter_avatar_female_lod1.glb", "distance": 10 },
        { "level": 2, "file": "starter_avatar_female_lod2.glb", "distance": 22 }
      ]
    }
  },
  "mods": {
    "jacket_field": {
      "label": "Field jacket",
      "attach": "torso",
      "procedural": "jacket_field",
      "note": "Creator MOD layer — stackable gear"
    },
    "vest_tactical": {
      "label": "Tactical vest",
      "attach": "torso",
      "procedural": "vest_tactical"
    },
    "pack_field": {
      "label": "Field pack",
      "attach": "torso",
      "procedural": "pack_field"
    },
    "hat_cap": {
      "label": "Cap",
      "attach": "head",
      "procedural": "hat_cap"
    },
    "goggles_tech": {
      "label": "Tech goggles",
      "attach": "head",
      "procedural": "goggles_tech"
    }
  },
  "hair": {
    "none": { "procedural": "hairCap" },
    "hair_short_m": { "glb": "hair_short_m.glb", "attach": "hair_anchor", "fpsHide": true },
    "hair_long_f": { "glb": "hair_long_f.glb", "attach": "hair_anchor", "fpsHide": true },
    "hair_bun_f": { "glb": "hair_bun_f.glb", "attach": "hair_anchor", "fpsHide": true }
  },
  "textures": {
    "skin": { "slug": "starter_skin", "slots": ["albedo", "roughness"], "hilod": true },
    "shirt": { "slug": "starter_fabric", "slots": ["albedo", "roughness"], "hilod": true },
    "hair": { "slug": "hair_alpha", "slots": ["albedo", "alpha"], "hilod": true, "transparent": true }
  },
  "roles": {
    "player": { "bodyId": "male_default", "hairId": "hair_short_m" },
    "guide_npc": { "bodyId": "male_default", "hairId": "hair_short_m" },
    "guard_npc": { "glb": "starter_npc_guard.glb", "heightM": 1.75 },
    "mechanic_npc": { "glb": "starter_npc_mech.glb", "heightM": 1.75 },
    "tesla_guide": { "bodyId": "male_default", "hairId": "hair_short_m" }
  },
  "blenderExport": {
    "format": "glb",
    "applyTransforms": true,
    "includeAnimations": true,
    "script": "npm run blender:avatar -- --blend your_scene.blend --object Avatar --output import"
  }
}
