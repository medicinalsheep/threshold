{
  "format": "threshold-negative-lod",
  "version": 4,
  "enabled": true,
  "defaultDistance": 72,
  "hysteresis": 8,
  "maxUpdatesPerFrame": 48,
  "fadeStart": 0.72,
  "fadeEnd": 1.35,
  "fadeMinOpacity": 0.88,
  "preserveMapDefault": false,
  "disableCastShadowWhenFlat": true,
  "forceFullWhenSelected": true,
  "envBlend": 0.4,
  "envLightBoost": 0.22,
  "appearanceSample": true,
  "autoEnableTiers": ["compatibility", "balanced", "realistic"],
  "autoEnableMinObjects": 3,
  "autoEnableStaticOnly": true,
  "distanceByTier": {
    "compatibility": 52,
    "balanced": 68,
    "realistic": 88,
    "ultra": 110
  },
  "floor": {
    "enabled": true,
    "autoTiersOnly": true,
    "cameraHeight": 18,
    "distance": 72,
    "hysteresis": 4,
    "preserveMap": true,
    "pathC": true,
    "pathCMinInstances": 16,
    "pathCNearDistance": 36
  },
  "excludeFlags": [
    "isPlayer",
    "isFloor",
    "negativeLodExempt",
    "isHero",
    "lockedFloor"
  ],
  "note": "Far unlit LOD with longer distances + per-material appearance tinted by scene fog/hemi/sun so flats blend into the world. Auto on static props for Lite/Mobile/Realistic."
}
