{
  "format": "threshold-negative-lod",
  "version": 5,
  "enabled": true,
  "defaultDistance": 100,
  "hysteresis": 12,
  "maxUpdatesPerFrame": 48,
  "fadeStart": 0.82,
  "fadeEnd": 1.45,
  "fadeMinOpacity": 0.94,
  "preserveMapDefault": false,
  "disableCastShadowWhenFlat": true,
  "forceFullWhenSelected": true,
  "envBlend": 0.18,
  "envLightBoost": 0.55,
  "unlitLift": 1.12,
  "ambientFloor": 0.62,
  "metalEnvMix": 0.22,
  "mapColorScale": 1.05,
  "appearanceSample": true,
  "autoEnableTiers": ["compatibility", "balanced", "realistic"],
  "autoEnableMinObjects": 3,
  "autoEnableStaticOnly": true,
  "distanceByTier": {
    "compatibility": 72,
    "balanced": 95,
    "realistic": 125,
    "ultra": 165
  },
  "floor": {
    "enabled": true,
    "autoTiersOnly": true,
    "cameraHeight": 90,
    "distance": 160,
    "hysteresis": 12,
    "preserveMap": true,
    "pathC": false,
    "pathCMinInstances": 48,
    "pathCNearDistance": 80,
    "note": "pathC off by default — near/far slab flip looked like texture thrash on workspace pad"
  },
  "excludeFlags": [
    "isPlayer",
    "isFloor",
    "negativeLodExempt",
    "isHero",
    "lockedFloor"
  ],
  "note": "v5 gameplay: farther thresholds; unlitLift+ambientFloor bake missing lights into flat color (no dark muddy flats); soft fog pull; align with visibility nearDistance."
}
