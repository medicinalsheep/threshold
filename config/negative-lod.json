{
  "format": "threshold-negative-lod",
  "version": 2,
  "enabled": true,
  "defaultDistance": 40,
  "hysteresis": 4,
  "maxUpdatesPerFrame": 48,
  "fadeStart": 0.85,
  "fadeEnd": 1.15,
  "preserveMapDefault": false,
  "disableCastShadowWhenFlat": true,
  "forceFullWhenSelected": true,
  "autoEnableTiers": ["compatibility", "balanced"],
  "autoEnableMinObjects": 6,
  "distanceByTier": {
    "compatibility": 28,
    "balanced": 40,
    "realistic": 55,
    "ultra": 55
  },
  "excludeFlags": [
    "isPlayer",
    "isFloor",
    "negativeLodExempt",
    "isHero",
    "lockedFloor"
  ],
  "note": "Shader LOD: far objects use unlit MeshBasicMaterial. autoEnableTiers applies on Lite/Mobile graphics without hand-flagging every prop."
}
