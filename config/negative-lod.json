{
  "format": "threshold-negative-lod",
  "version": 3,
  "enabled": true,
  "defaultDistance": 40,
  "hysteresis": 4,
  "maxUpdatesPerFrame": 48,
  "fadeStart": 0.85,
  "fadeEnd": 1.15,
  "preserveMapDefault": false,
  "disableCastShadowWhenFlat": true,
  "forceFullWhenSelected": true,
  "autoEnableTiers": ["compatibility", "balanced"],
  "autoEnableMinObjects": 6,
  "distanceByTier": {
    "compatibility": 28,
    "balanced": 40,
    "realistic": 55,
    "ultra": 55
  },
  "floor": {
    "enabled": true,
    "autoTiersOnly": true,
    "cameraHeight": 12,
    "distance": 45,
    "hysteresis": 2,
    "preserveMap": true
  },
  "excludeFlags": [
    "isPlayer",
    "isFloor",
    "negativeLodExempt",
    "isHero",
    "lockedFloor"
  ],
  "note": "Shader LOD: far unlit. Multi-mat 1:1 + shared clone + skinned safe. Floor path B: ground/instanced swap when camera high/far on Lite/Mobile."
}
