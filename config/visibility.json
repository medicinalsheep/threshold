{
  "format": "threshold-visibility",
  "version": 2,
  "enabled": true,
  "nearDistance": 40,
  "farDistance": 60,
  "frustumMargin": 0.08,
  "frameHysteresis": 6,
  "maxUpdatesPerFrame": 96,
  "focusFlags": [
    "isPlayer",
    "isHero",
    "alwaysProcess",
    "negativeLodExempt"
  ],
  "spatial": {
    "enabled": true,
    "minObjects": 120,
    "cellSize": 32,
    "cameraRing": 2,
    "fullSweepEvery": 45,
    "rebuildOnCountChange": true
  },
  "sleep": {
    "enabled": true,
    "disableShadowOnD": true,
    "disableShadowOnE": true,
    "physicsSleepOnE": true,
    "physicsSleepOnD": false,
    "neverSleepFlags": [
      "isPlayer",
      "isHero",
      "alwaysProcess",
      "isProjectile",
      "isDriven",
      "negativeLodExempt",
      "noCulledSleep"
    ]
  },
  "classes": {
    "A": "focus — full process",
    "B": "on-screen near — full PBR",
    "C": "on-screen far — negativeLOD flat candidate",
    "D": "off-screen near — light JS",
    "E": "off-screen far — max skip"
  },
  "note": "E0–E4: classify + sleep + spatial buckets when object count is high. Camera-local; do not network _visClass."
}
