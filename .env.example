# Threshold env (copy to .env.local — gitignored)

# xAI Grok API (Agent Portal generation)
# VITE_XAI_MODEL=grok-4.5
# VITE_XAI_API_BASE=https://api.x.ai/v1

# X (Twitter) OAuth 2.0 — Sign in with X
# Create SPA app at https://developer.x.com with OAuth 2.0 + PKCE
# Callback URLs must match exactly (include trailing slash if you use one):
#   https://medicinalsheep.github.io/threshold/
#   http://localhost:5173/
#   http://127.0.0.1:5173/
VITE_X_CLIENT_ID=
# Optional override (defaults to current origin + path):
# VITE_X_REDIRECT_URI=https://medicinalsheep.github.io/threshold/
# OAuth scopes used: tweet.read tweet.write users.read offline.access

# Ollama
# VITE_OLLAMA_URL=http://127.0.0.1:11435
